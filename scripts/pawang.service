[Unit]
Description=Pawang Multi-Agent Gateway
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/pawang
EnvironmentFile=/root/pawang/.env
ExecStart=/usr/bin/python3 /root/pawang/main.py
Restart=on-failure
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5

# Clean shutdown
KillMode=mixed
TimeoutStopSec=10

# Logging
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
